# Safe template for local gateway mode.
# Copy this file once, then edit only the values you need:
#   cp examples/provider-gateway/gateway.env.example examples/provider-gateway/gateway.env
#
# Keep gateway.env local-only. It is gitignored and should never be committed.

# Provider API keys used by LiteLLM.
# Fill in only the provider you actually plan to route to.
OPENAI_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=

# Anthropic-compatible local gateway settings used by this CLI.
export ANTHROPIC_BASE_URL=http://127.0.0.1:4000

# Must match general_settings.master_key in examples/provider-gateway/litellm.yaml.
export ANTHROPIC_API_KEY=sk-claude-code-local

# Must match one of the route names defined in examples/provider-gateway/litellm.yaml.
# Supported routes in this repo:
# - openai-via-gateway
# - gemini-via-gateway
# - deepseek-via-gateway
# - openrouter-via-gateway
export ANTHROPIC_MODEL=openrouter-via-gateway

# Side features can use the same route unless you intentionally split them.
export ANTHROPIC_SMALL_FAST_MODEL=openrouter-via-gateway

# Optional startup branding.
# Allowed values: starpaw | cyber-fox | baby-otter | pixel-bunny | openai-neon
export CLI_BRAND=starpaw

# Optional display name shown in the CLI header.
# export CLI_BRAND_NAME="My Local CLI"

# Optional mascot override independent from CLI_BRAND.
# Allowed values: cat | fox | otter | bunny | robot
# export CLI_MASCOT=robot

# Notes:
# - GOOGLE_API_KEY and GEMINI_API_KEY are treated as Gemini aliases by the helper scripts.
# - In gateway mode, ANTHROPIC_API_KEY is the local LiteLLM master key, not an Anthropic cloud key.
